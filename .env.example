# ============================================
# Daemon Desktop Pet — Secrets & Environment
# ============================================
# Copy this file to .env and fill in your keys.
# NEVER commit the actual .env file.
#
# After filling .env, run:
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env  (Windows)

# --- LLM / OpenCode ---
# Your OpenCode API key for LLM access
OPENCODE_API_KEY=your-opencode-api-key-here

# --- Firebase ---
# API key for Firebase Auth REST API (from Firebase Console -> Project Settings -> Web API Key)
FIREBASE_API_KEY=your-firebase-api-key-here

# --- Firebase Project ID (optional override) ---
# Defaults to "daemon-87f81" if not set
FIREBASE_PROJECT_ID=daemon-87f81

# --- Observability (optional) ---
# OpenTelemetry OTLP endpoint for traces
OTLP_ENDPOINT=
